# Copia este archivo como ".env" y completa con tus datos reales.
# NUNCA subas el archivo ".env" real a GitHub.

# Cadena de conexión de MongoDB Atlas (Atlas > Connect > Drivers)
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/prevencion_riesgos?retryWrites=true&w=majority

# Puerto donde correrá la API
PORT=3000
